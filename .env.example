# Deepy MCP server configuration.
# Copy this file to `.env` and fill in your values.
# NEVER commit a real key. The API key is read ONLY from the environment,
# never from tool arguments or user chat text, and is never logged.

# Base URL of the Deepy public API (no trailing slash).
# Deepy API base URL (no trailing slash)::
DEEPY_API_BASE_URL=https://app.prod.einfra.tech

# Your personal Deepy API key. Create it in the Deepy web app under
# "API access"; it is shown only once. Format: sk_live_… or sk_test_…
DEEPY_API_KEY=<paste_your_key>

# Optional: log verbosity for the server's stderr diagnostics.
# One of: debug | info | warn | error | silent. Defaults to "info".
# (The API key is redacted from every log line regardless of level.)
# DEEPY_LOG_LEVEL=info
